#!/usr/bin/env python3
"""lcc — lossless-code CLI entry point."""
import os
import sys

SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
os.environ.setdefault("LOSSLESS_HOME", os.path.dirname(SCRIPT_DIR))
sys.path.insert(0, SCRIPT_DIR)

import lcc as _lcc

if __name__ == "__main__":
    _lcc.main()
