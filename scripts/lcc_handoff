#!/bin/bash
# lcc_handoff — show/generate handoff for current session
if [ -n "${LOSSLESS_HOME:-}" ]; then
    SCRIPTS_DIR="$LOSSLESS_HOME/scripts"
else
    SOURCE="${BASH_SOURCE[0]:-$0}"
    if [ "${SOURCE#*/}" = "$SOURCE" ]; then
        FOUND="$(command -v "$SOURCE" 2>/dev/null || true)"
        [ -n "$FOUND" ] && SOURCE="$FOUND"
    fi
    if command -v readlink >/dev/null 2>&1; then
        RESOLVED="$(readlink -f "$SOURCE" 2>/dev/null || true)"
        [ -n "$RESOLVED" ] && SOURCE="$RESOLVED"
    fi
    SCRIPTS_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    export LOSSLESS_HOME="$(cd "$SCRIPTS_DIR/.." && pwd)"
fi
exec python3 "$SCRIPTS_DIR/lcc.py" handoff "$@"
